<mvc:View controllerName="FI_PaymentRM_All_App.controller.View1" xmlns:html="http://www.w3.org/1999/xhtml" xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:f="sap.f" xmlns:fb="sap.ui.comp.filterbar" xmlns:smartTable="sap.ui.comp.smarttable"
	xmlns:svm="sap.ui.comp.smartvariants" xmlns:layout="sap.ui.layout" xmlns:table="sap.ui.table" xmlns:suite="sap.suite.ui.commons"
	xmlns:viz="sap.viz.ui5.controls" xmlns:vizData="sap.viz.ui5.data" xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds">
	<App>
		<pages>
			<!--<Page title="{i18n>title}">-->
			<!--	<content></content>-->
