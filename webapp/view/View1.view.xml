<mvc:View controllerName="FI_PaymentRM_All_App.controller.View1" xmlns:html="http://www.w3.org/1999/xhtml" xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:f="sap.f" xmlns:fb="sap.ui.comp.filterbar" xmlns:smartTable="sap.ui.comp.smarttable"
	xmlns:svm="sap.ui.comp.smartvariants" xmlns:layout="sap.ui.layout" xmlns:table="sap.ui.table" xmlns:suite="sap.suite.ui.commons"
	xmlns:viz="sap.viz.ui5.controls" xmlns:vizData="sap.viz.ui5.data" xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds">
	<App>
		<pages>
			<!--<Page title="{i18n>title}">-->
			<!--	<content></content>-->
			<!--</Page>-->
			<f:DynamicPage id="pageId" headerExpanded="{/headerExpanded}">
				<f:title>
					<f:DynamicPageTitle>
						<f:heading>
							<svm:SmartVariantManagement id="svm" showExecuteOnSelection="true"/>
						</f:heading>
						<f:expandedContent>
							<Label id="expandedLabel" text="No filters active"/>
						</f:expandedContent>
						<f:snappedContent>
							<Label id="snappedLabel" text="No filters active"/>
						</f:snappedContent>
					</f:DynamicPageTitle>
				</f:title>
				<f:header>
					<f:DynamicPageHeader>
						<f:content>
							<fb:FilterBar id="filterbar" persistencyKey="myPersKey" useToolbar="false" search=".onSearch" filterChange=".onFilterChange"
								afterVariantLoad=".onAfterVariantLoad">
								<fb:filterGroupItems>
									<fb:FilterGroupItem name="pa_bukrs" label="Company Code" groupName="Group1" visibleInFilterBar="true">
										<fb:control>
											<Input id="inputCompanyCode" editable="false" class="sapUiSmallMarginBottom" type="Text" placeholder="Enter Value" showValueHelp="false"
												value="1000" required="true" liveChange="onLiveChange"/>
										</fb:control>
									</fb:FilterGroupItem>
									<fb:FilterGroupItem name="pa_prctr" label="Profit Center" groupName="Group1" visibleInFilterBar="true">
										<fb:control>
											<Input id="inputProfitCenter" showValueHelp="true" valueHelpRequest=".onProfitCenterDialog" placeholder="Select Profit Center"
												showClearIcon="true" required="true" liveChange=".onProfitCenterClear"/>
										</fb:control>
									</fb:FilterGroupItem>
									<fb:FilterGroupItem name="pa_gjahr" label="Fiscal Year" groupName="Group1" visibleInFilterBar="true">
										<fb:control>
											<DatePicker id="yearPicker" displayFormat="yyyy" valueFormat="yyyy" change="onYearChange" placeholder="Select Year"
												class="round sapUiSmallMarginBottom"/>
										</fb:control>
									</fb:FilterGroupItem>
									<fb:FilterGroupItem name="pa_period_from" label="From Period" groupName="Group1" visibleInFilterBar="true">
										<fb:control>
											<Input id="inputFromPeriod" showValueHelp="true" valueHelpRequest="handleValueDialogFromPeriod" placeholder="Select From Period"
												showClearIcon="true" required="true"/>
										</fb:control>
									</fb:FilterGroupItem>
									<fb:FilterGroupItem name="inputToPeriod" label="To Period" groupName="Group1" visibleInFilterBar="true">
										<fb:control>
											<Input id="inputToPeriod" showValueHelp="true" valueHelpRequest="handleValueDialogToPeriod" placeholder="Select To Period"
												showClearIcon="true" required="true"/>
										</fb:control>
									</fb:FilterGroupItem>
								</fb:filterGroupItems>
							</fb:FilterBar>
						</f:content>
					</f:DynamicPageHeader>
				</f:header>
				<f:content>
					<suite:ChartContainer id="chartContainer" showFullScreen="true" showPersonalization="false" autoAdjustHeight="false" title="Payment RM">
						<!-- Chart Content -->
						<suite:content>
							<suite:ChartContainerContent icon="sap-icon://bar-chart" title="Chart View">
								<suite:content>
									<viz:VizFrame id="idVizFrame" vizType="column" height="400px" width="100%">
										<viz:dataset>
											<vizData:FlattenedDataset>
												<vizData:dimensions>
													<vizData:DimensionDefinition name="Product" value="{Product}"/>
												</vizData:dimensions>
												<vizData:measures>
													<vizData:MeasureDefinition name="Revenue" value="{Revenue}"/>
												</vizData:measures>
											</vizData:FlattenedDataset>
										</viz:dataset>
										<viz:feeds>
											<vizFeeds:FeedItem uid="valueAxis" type="Measure" values="Revenue"/>
											<vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="Product"/>
										</viz:feeds>
									</viz:VizFrame>
								</suite:content>
							</suite:ChartContainerContent>
							<!-- Table Content -->
							<suite:ChartContainerContent icon="sap-icon://table-chart" title="Table View">
								<suite:content>
									<table:Table id="idTable" rows="{/listData}">
										<table:columns>
											<table:Column>
												<Label text="Profit Center"/>
												<table:template>
													<Text text="{PRCTR}"/>
												</table:template>
											</table:Column>
											<table:Column>
												<Label text="Total Amount"/>
												<table:template>
													<Text text="{HSL}"/>
												</table:template>
											</table:Column>
										</table:columns>
									</table:Table>
								</suite:content>
							</suite:ChartContainerContent>
						</suite:content>
					</suite:ChartContainer>
				</f:content>
			</f:DynamicPage>
		</pages>
	</App>
</mvc:View>