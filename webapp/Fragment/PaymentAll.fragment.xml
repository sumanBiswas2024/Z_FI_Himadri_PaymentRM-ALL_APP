<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:table="sap.ui.table" xmlns:suite="sap.suite.ui.commons"
	xmlns:viz="sap.viz.ui5.controls" xmlns:vizData="sap.viz.ui5.data" xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds">
	<suite:ChartContainer id="chartContainer" showFullScreen="true" showPersonalization="false" autoAdjustHeight="false"
		title="Payment All Summary">
		<!-- Chart Content -->
		<suite:content>
			<suite:ChartContainerContent icon="sap-icon://bar-chart" title="Chart View">
				<suite:content>
					<VBox>
						<!-- Toolbar with ComboBox -->
						<!--<Title text="Payment RM Analysis Chart" level="H2"/>-->
						<Toolbar>
							<content>
								<FlexBox width="90%" direction="Row" height="auto" id="DepartmentView" wrap="Wrap" justifyContent="SpaceAround" alignItems="Center"
									visible="true">
									<RadioButtonGroup id="onSelectChartType" columns="5" select="onSelectChartType">
										<RadioButton id="columnChart" text="Column Chart"/>
										<RadioButton id="pieChart" text="Pie Chart"/>
										<!--<RadioButton id="lineChart" text="Line Chart"/>-->
										<!--<RadioButton id="donutChart" text="Donut Chart"/>-->
									</RadioButtonGroup>
								</FlexBox>
							</content>
						</Toolbar>
						<viz:VizFrame id="idVizFrame3" vizType="column" height="400px" width="100%"
							vizProperties="{ plotArea: { drawingEffect: 'glossy' }, dataLabel: { visible: true, showTotal: true }, interaction: { selectability: { mode: 'none' }}}"
							uiConfig="{ 'applicationSet': 'fiori' }">
							<viz:dataset>
								<vizData:FlattenedDataset data="{allListData>/}">
									<vizData:dimensions>
										<vizData:DimensionDefinition name="Profit Center" value="{allListData>PRCTR}"/>
									</vizData:dimensions>
									<vizData:measures>
										<vizData:MeasureDefinition name="Total Amount" value="{allListData>HSL}"/>
									</vizData:measures>
								</vizData:FlattenedDataset>
							</viz:dataset>
							<viz:feeds>
								<vizFeeds:FeedItem uid="valueAxis" type="Measure" values="Total Amount"/>
								<vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="Profit Center"/>
							</viz:feeds>
						</viz:VizFrame>
					</VBox>
				</suite:content>
			</suite:ChartContainerContent>
			<!-- Table Content -->
			<suite:ChartContainerContent icon="sap-icon://table-chart" title="Table View">
				<suite:content>
					<!--<table:Table id="idTable" rows="{listData>/}" selectionMode="None" >-->
					<!--	<table:columns>-->
					<!--		<table:Column>-->
					<!--			<Label text="Profit Center"/>-->
					<!--			<table:template>-->
					<!--				<Text text="{listData>PRCTR}"/>-->
					<!--			</table:template>-->
					<!--		</table:Column>-->
					<!--		<table:Column>-->
					<!--			<Label text="Total Amount"/>-->
					<!--			<table:template>-->
					<!--				<Text text="{listData>HSL}"/>-->
					<!--			</table:template>-->
					<!--		</table:Column>-->
					<!--		<table:Column>-->
					<!--			<Label text="Action"/>-->
					<!--			<table:template>-->
					<!--				<Button text="Navigate" press=".onNavigatePress"/>-->
					<!--			</table:template>-->
					<!--		</table:Column>-->
					<!--	</table:columns>-->
					<!--</table:Table>-->
					<Table id="idTable3" mode="None" items="{allListData>/}" class="pdfTable boldText">
						<columns>
							<Column>
								<Text text="Profit Center"/>
							</Column>
							<Column>
								<Text text="Total Amount"/>
							</Column>
							<!--<Column>-->
							<!--	<Text text="Action"/>-->
							<!--</Column>-->
						</columns>
						<items>
							<ColumnListItem type="Navigation" press=".onNavigatePress">
								<cells>
									<Text text="{allListData>PRCTR}"/>
									<Text text="{allListData>HSL}"/>
									<!--<Button text="Navigate" press=".onNavigatePress"/>-->
								</cells>
							</ColumnListItem>
						</items>
					</Table>
				</suite:content>
			</suite:ChartContainerContent>
		</suite:content>
	</suite:ChartContainer>
</core:FragmentDefinition>